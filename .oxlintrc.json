{
  "plugins": ["import", "react", "jsx-a11y", "nextjs"],
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": "off"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  },
  "ignorePatterns": [".next/**", "out/**", "build/**", "next-env.d.ts"]
}
